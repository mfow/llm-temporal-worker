{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-temporal-worker.dev/schema/llm.temporal/compact/v1/compact-response.json",
  "title": "llm.temporal/compact/v1 CompactResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "operation_key", "operation_id", "status", "checkpoint", "cache", "cost"],
  "properties": {
    "api_version": {"const": "llm.temporal/compact/v1"},
    "operation_key": {"type": "string", "minLength": 1},
    "operation_id": {"type": "string", "minLength": 1},
    "status": {"const": "completed"},
    "checkpoint": {"$ref": "#/$defs/checkpoint"},
    "cache": {"$ref": "#/$defs/cache_disposition"},
    "provenance": {"$ref": "#/$defs/provenance"},
    "usage": {"$ref": "#/$defs/usage"},
    "cost": {"$ref": "#/$defs/cost"},
    "diagnostics": {"type": "array", "items": {"$ref": "#/$defs/diagnostic"}}
  },
  "$defs": {
    "checkpoint": {"type": "object", "additionalProperties": false, "required": ["handle", "parent", "kind", "depth"], "properties": {"handle": {"type": "string", "minLength": 1}, "parent": {"type": "string", "minLength": 1}, "kind": {"const": "compaction"}, "depth": {"type": "integer", "minimum": 0}}},
    "cache_disposition": {"type": "object", "additionalProperties": false, "required": ["disposition", "variant"], "properties": {"disposition": {"enum": ["disabled", "miss_populated", "hit", "miss_not_populated"]}, "variant": {"const": 0}, "entry_age_seconds": {"type": "integer", "minimum": 0}}},
    "provenance": {"type": "object", "additionalProperties": false, "required": ["source"], "properties": {"source": {"enum": ["provider", "worker_cache"]}, "origin_operation_id": {"type": "string"}, "policy": {"type": "string"}}},
    "usage": {"type": "object", "additionalProperties": false, "required": ["input_tokens", "output_tokens", "reasoning_tokens", "cache_read_tokens", "cache_write_tokens"], "properties": {"input_tokens": {"type": "integer", "minimum": 0}, "output_tokens": {"type": "integer", "minimum": 0}, "reasoning_tokens": {"type": "integer", "minimum": 0}, "cache_read_tokens": {"type": "integer", "minimum": 0}, "cache_write_tokens": {"type": "integer", "minimum": 0}}},
    "cost": {"oneOf": [{"type": "object", "additionalProperties": false, "required": ["status", "actual_cost_usd", "method"], "properties": {"status": {"const": "exact"}, "actual_cost_usd": {"type": "string", "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,18})?$"}, "method": {"enum": ["provider_reported", "catalog_usage"]}}}, {"type": "object", "additionalProperties": false, "required": ["status", "actual_cost_usd", "unknown_reason"], "properties": {"status": {"const": "unknown"}, "actual_cost_usd": {"type": "null"}, "unknown_reason": {"enum": ["provider_did_not_report_cost", "catalog_incomplete", "state_unavailable", "ambiguous_dispatch"]}}}]},
    "diagnostic": {"type": "object", "additionalProperties": false, "required": ["code", "severity", "message"], "properties": {"code": {"type": "string"}, "severity": {"enum": ["info", "warning", "error"]}, "message": {"type": "string"}}}
  }
}
