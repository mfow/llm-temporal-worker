{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-temporal-worker.dev/schema/llm.temporal/query/v1/query-request.json",
  "title": "llm.temporal/query/v1 QueryRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "operation_key", "context", "kind", "query"],
  "properties": {
    "api_version": {"const": "llm.temporal/query/v1"},
    "operation_key": {"type": "string", "minLength": 1, "maxLength": 256},
    "context": {"$ref": "#/$defs/context"},
    "kind": {"enum": ["provider_status", "model_inventory", "credit_status", "budget_status", "spend_summary"]},
    "query": {"$ref": "#/$defs/query"}
  },
  "$defs": {
    "context": {"type": "object", "additionalProperties": false, "required": ["tenant", "project", "actor"], "properties": {"tenant": {"type": "string", "minLength": 1}, "project": {"type": "string", "minLength": 1}, "actor": {"type": "string", "minLength": 1}}},
    "provider_status": {"type": "object", "additionalProperties": false, "properties": {"provider": {"type": "string"}, "endpoint": {"type": "string"}, "availability": {"enum": ["available", "degraded", "unavailable"]}, "include_healthy": {"type": "boolean"}, "refresh_if_older_than_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}, "page_size": {"type": "integer", "minimum": 1, "maximum": 1000}, "cursor": {"type": ["string", "null"], "maxLength": 512}}},
    "model_inventory": {"type": "object", "additionalProperties": false, "properties": {"provider": {"type": "string"}, "endpoint": {"type": "string"}, "model_prefix": {"type": "string"}, "lifecycle": {"enum": ["available", "deprecated", "unavailable", "unknown"]}, "refresh_if_older_than_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}, "page_size": {"type": "integer", "minimum": 1, "maximum": 1000}, "cursor": {"type": ["string", "null"], "maxLength": 512}}},
    "credit_status": {"type": "object", "additionalProperties": false, "properties": {"provider": {"type": "string"}, "endpoint": {"type": "string"}, "include_ok": {"type": "boolean"}, "refresh_if_older_than_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}, "page_size": {"type": "integer", "minimum": 1, "maximum": 1000}, "cursor": {"type": ["string", "null"], "maxLength": 512}}},
    "budget_status": {"type": "object", "additionalProperties": false, "properties": {"policy_key": {"type": "string"}, "active_at": {"type": "string", "format": "date-time"}, "include_windows": {"type": "boolean"}}},
    "spend_summary": {"type": "object", "additionalProperties": false, "required": ["start_time", "end_time"], "properties": {"start_time": {"type": "string", "format": "date-time"}, "end_time": {"type": "string", "format": "date-time"}, "group_by": {"type": "array", "uniqueItems": true, "items": {"enum": ["operation_kind", "provider", "model"]}}, "operation_kinds": {"type": "array", "uniqueItems": true, "items": {"enum": ["generate", "compact", "query"]}}}},
    "query": {"anyOf": [{"$ref": "#/$defs/provider_status"}, {"$ref": "#/$defs/model_inventory"}, {"$ref": "#/$defs/credit_status"}, {"$ref": "#/$defs/budget_status"}, {"$ref": "#/$defs/spend_summary"}]}
  }
}
