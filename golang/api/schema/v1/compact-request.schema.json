{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-temporal-worker.dev/schema/llm.temporal/compact/v1/compact-request.json",
  "title": "llm.temporal/compact/v1 CompactRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "operation_key", "context", "parent"],
  "properties": {
    "api_version": {"const": "llm.temporal/compact/v1"},
    "operation_key": {"type": "string", "minLength": 1, "maxLength": 256},
    "context": {"$ref": "#/$defs/context"},
    "parent": {"type": "string", "minLength": 1, "maxLength": 512},
    "policy": {"$ref": "#/$defs/policy"},
    "cache": {"$ref": "#/$defs/cache"}
  },
  "$defs": {
    "context": {"type": "object", "additionalProperties": false, "required": ["tenant", "project", "actor"], "properties": {"tenant": {"type": "string", "minLength": 1, "maxLength": 256}, "project": {"type": "string", "minLength": 1, "maxLength": 256}, "actor": {"type": "string", "minLength": 1, "maxLength": 256}}},
    "policy": {"type": "object", "additionalProperties": false, "properties": {"target_tokens": {"type": "integer", "minimum": 1, "maximum": 10000000}, "summary_style": {"enum": ["concise", "balanced", "detailed"]}}},
    "cache": {"type": "object", "additionalProperties": false, "required": ["max_age_seconds"], "properties": {"max_age_seconds": {"type": "integer", "minimum": 1, "maximum": 31536000}, "variant": {"const": 0}}}
  }
}
