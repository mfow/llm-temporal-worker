{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-temporal-worker.dev/schema/llm.temporal/v1/generate-response.json",
  "title": "llm.temporal/v1 GenerateResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["api_version", "operation_key", "operation_id", "status", "output", "checkpoint", "cache", "cost"],
  "properties": {
    "api_version": {"const": "llm.temporal/v1"},
    "operation_key": {"type": "string", "minLength": 1},
    "operation_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["completed", "tool_calls", "refused", "length", "content_filtered"]},
    "output": {"type": "array", "items": {"$ref": "#/$defs/item"}},
    "checkpoint": {"$ref": "#/$defs/generate_checkpoint"},
    "cache": {"$ref": "#/$defs/cache_disposition"},
    "route": {"$ref": "#/$defs/route"},
    "usage": {"$ref": "#/$defs/usage"},
    "cost": {"$ref": "#/$defs/cost"},
    "diagnostics": {"type": "array", "items": {"$ref": "#/$defs/diagnostic"}}
  },
  "$defs": {
    "checkpoint": {
      "type": "object", "additionalProperties": false,
      "required": ["handle", "kind", "depth"],
      "properties": {
        "handle": {"type": "string", "minLength": 1, "maxLength": 512},
        "parent": {"type": ["string", "null"], "maxLength": 512},
        "kind": {"enum": ["generation", "compaction", "cache_replay"]},
        "depth": {"type": "integer", "minimum": 0, "maximum": 2147483647}
      }
    },
    "generate_checkpoint": {
      "type": "object", "additionalProperties": false,
      "required": ["handle", "kind", "depth"],
      "properties": {
        "handle": {"type": "string", "minLength": 1, "maxLength": 512},
        "parent": {"type": ["string", "null"], "maxLength": 512},
        "kind": {"enum": ["generation", "cache_replay"]},
        "depth": {"type": "integer", "minimum": 0, "maximum": 2147483647}
      }
    },
    "cache_disposition": {
      "type": "object", "additionalProperties": false,
      "required": ["disposition", "variant"],
      "properties": {
        "disposition": {"enum": ["disabled", "miss_populated", "hit", "miss_not_populated"]},
        "variant": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "entry_age_seconds": {"type": "integer", "minimum": 0}
      }
    },
    "cost": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["status", "actual_cost_usd", "method"], "properties": {"status": {"const": "exact"}, "actual_cost_usd": {"type": "string", "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,18})?$"}, "method": {"enum": ["provider_reported", "catalog_usage", "control_query_zero"]}, "catalog_version": {"type": "string"}}},
        {"type": "object", "additionalProperties": false, "required": ["status", "actual_cost_usd", "unknown_reason"], "properties": {"status": {"const": "unknown"}, "actual_cost_usd": {"type": "null"}, "unknown_reason": {"enum": ["provider_did_not_report_cost", "catalog_incomplete", "state_unavailable", "ambiguous_dispatch"]}}}
      ]
    },
    "route": {"type": "object", "additionalProperties": false, "properties": {"route_id": {"type": "string"}, "endpoint_id": {"type": "string"}, "api_family": {"type": "string"}, "requested_model": {"type": "string"}, "resolved_model": {"type": "string"}}},
    "usage": {"type": "object", "additionalProperties": false, "required": ["input_tokens", "output_tokens", "reasoning_tokens", "cache_read_tokens", "cache_write_tokens"], "properties": {"input_tokens": {"type": "integer", "minimum": 0}, "output_tokens": {"type": "integer", "minimum": 0}, "reasoning_tokens": {"type": "integer", "minimum": 0}, "cache_read_tokens": {"type": "integer", "minimum": 0}, "cache_write_tokens": {"type": "integer", "minimum": 0}}},
    "diagnostic": {"type": "object", "additionalProperties": false, "required": ["code", "severity", "message"], "properties": {"code": {"type": "string", "minLength": 1}, "severity": {"enum": ["info", "warning", "error"]}, "path": {"type": "string"}, "message": {"type": "string", "minLength": 1}, "details": {"type": "object", "additionalProperties": {"type": "string"}}}},
    "item": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["kind", "actor", "content"], "properties": {"kind": {"const": "message"}, "actor": {"enum": ["human", "model"]}, "content": {"type": "array", "items": {"$ref": "#/$defs/part"}}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "id", "name", "arguments"], "properties": {"kind": {"const": "tool_call"}, "id": {"type": "string"}, "name": {"type": "string"}, "arguments": {}}},
        {"type": "object", "additionalProperties": false, "required": ["kind", "call_id", "content", "is_error"], "properties": {"kind": {"const": "tool_result"}, "call_id": {"type": "string"}, "name": {"type": "string"}, "content": {"type": "array", "items": {"$ref": "#/$defs/part"}}, "is_error": {"type": "boolean"}}}
      ]
    },
    "part": {"oneOf": [{"type": "object", "additionalProperties": false, "required": ["kind", "text"], "properties": {"kind": {"const": "text"}, "text": {"type": "string"}}}, {"type": "object", "additionalProperties": false, "required": ["kind", "value"], "properties": {"kind": {"const": "json"}, "value": {}}}, {"type": "object", "additionalProperties": false, "required": ["kind", "text"], "properties": {"kind": {"const": "refusal"}, "text": {"type": "string"}}}]}
  }
}
