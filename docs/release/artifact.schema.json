{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:llmtw:release-evidence-artifact:v1",
  "title": "LLM Temporal Worker redacted release-evidence summaries",
  "oneOf": [
    { "$ref": "#/$defs/gate_summary" },
    { "$ref": "#/$defs/fixture_manifest" },
    { "$ref": "#/$defs/redis_summary" },
    { "$ref": "#/$defs/temporal_summary" },
    { "$ref": "#/$defs/compose_summary" },
    { "$ref": "#/$defs/redacted_log" },
    { "$ref": "#/$defs/rendered_manifests" },
    { "$ref": "#/$defs/dependency_license" },
    { "$ref": "#/$defs/vulnerability_results" }
  ],
  "$defs": {
    "provenance_url": {
      "type": "string",
      "allOf": [
        {
          "pattern": "^https://[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)*(?:/[A-Za-z0-9._~!$&'()*+,;=:@/-]*)?$"
        },
        {
          "not": {
            "pattern": "^https://[0-9]+(?:\\.[0-9]+)+(?:/|$)"
          }
        },
        {
          "not": {
            "pattern": "^https://[^/]{254,}(?:/|$)"
          }
        }
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "redacted": {
      "const": true
    },
    "gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "status",
        "output_sha256",
        "output_bytes",
        "redacted"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": {
          "enum": ["test_summary", "race_summary", "fuzz_summary"]
        },
        "status": { "const": "pass" },
        "output_sha256": { "$ref": "#/$defs/sha256" },
        "output_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "fixture_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "status",
        "version",
        "fixtures",
        "redacted"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "fixture_manifest" },
        "status": { "const": "pass" },
        "version": { "const": 1 },
        "fixtures": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profile",
              "upstream_url",
              "upstream_date",
              "manifest_sha256"
            ],
            "properties": {
              "profile": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]{0,127}$"
              },
              "upstream_url": {
                "$ref": "#/$defs/provenance_url"
              },
              "upstream_date": {
                "type": "string",
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
              },
              "manifest_sha256": { "$ref": "#/$defs/sha256" }
            }
          }
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "redis_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "status", "service", "state", "health", "redacted"],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "redis_summary" },
        "status": { "const": "pass" },
        "service": { "const": "redis" },
        "state": { "const": "running" },
        "health": { "const": "healthy" },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "temporal_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "status", "service", "state", "health", "redacted"],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "temporal_summary" },
        "status": { "const": "pass" },
        "service": { "const": "temporal" },
        "state": { "const": "running" },
        "health": { "const": "healthy" },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "compose_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "status", "services", "redacted"],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "compose_summary" },
        "status": { "const": "pass" },
        "services": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["redis", "temporal"]
          }
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "redacted_log": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "status",
        "service",
        "source",
        "redaction_policy",
        "line_count",
        "input_bytes",
        "event_counts",
        "redacted"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": {
          "enum": ["redis_log", "temporal_log", "compose_log"]
        },
        "status": { "const": "pass" },
        "service": {
          "enum": ["redis", "temporal", "compose"]
        },
        "source": { "const": "docker_compose_logs" },
        "redaction_policy": { "const": "allowlist-v1" },
        "line_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100000
        },
        "input_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8388608
        },
        "event_counts": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 8,
          "propertyNames": {
            "enum": [
              "redacted_line",
              "redis_ready",
              "redis_initialized",
              "redis_loading",
              "temporal_started",
              "temporal_ready",
              "temporal_serving",
              "temporal_database_ready"
            ]
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100000
          }
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "rendered_manifests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "status", "manifests", "redacted"],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "rendered_manifests" },
        "status": { "const": "pass" },
        "manifests": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "sha256", "bytes", "objects"],
            "properties": {
              "source": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._/-]{1,256}$"
              },
              "sha256": { "$ref": "#/$defs/sha256" },
              "bytes": {
                "type": "integer",
                "minimum": 1,
                "maximum": 33554432
              },
              "objects": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10000
              }
            }
          }
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "dependency_license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "kind", "status", "baseline_sha256", "direct_modules", "redacted"],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "dependency_license" },
        "status": { "const": "pass" },
        "baseline_sha256": { "$ref": "#/$defs/sha256" },
        "direct_modules": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "version", "license", "source"],
            "properties": {
              "path": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._~+/-]{1,256}$"
              },
              "version": {
                "type": "string",
                "pattern": "^v[A-Za-z0-9.+-]{1,127}$"
              },
              "license": {
                "type": "string",
                "pattern": "^[A-Za-z0-9.+-]{1,64}$"
              },
              "source": {
                "$ref": "#/$defs/provenance_url"
              }
            }
          }
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    },
    "vulnerability_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "status",
        "components",
        "direct_module_count",
        "findings",
        "approved_findings",
        "redacted"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "kind": { "const": "vulnerability_results" },
        "status": { "const": "pass" },
        "components": {
          "type": "object",
          "additionalProperties": false,
          "required": ["test", "source", "go_mod", "vulnerability"],
          "properties": {
            "test": { "const": "pass" },
            "source": { "const": "pass" },
            "go_mod": { "const": "pass" },
            "vulnerability": { "const": "pass" }
          }
        },
        "direct_module_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128
        },
        "findings": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]{1,128}$"
          }
        },
        "approved_findings": {
          "type": "array",
          "maxItems": 128,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._:-]{1,128}$"
          }
        },
        "redacted": { "$ref": "#/$defs/redacted" }
      }
    }
  }
}
