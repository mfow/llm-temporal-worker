{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:llmtw:release-evidence:v1",
  "title": "LLM Temporal Worker release evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "image",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision"
      ],
      "properties": {
        "repository": {
          "$ref": "#/$defs/provenance_url"
        },
        "revision": {
          "type": "string",
          "pattern": "^[a-f0-9]{40,64}$"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "digest"
      ],
      "properties": {
        "reference": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_summary",
        "race_summary",
        "fuzz_summary",
        "fixture_manifest",
        "redis_summary",
        "temporal_summary",
        "compose_summary",
        "redis_log",
        "temporal_log",
        "compose_log",
        "rendered_manifests",
        "dependency_license",
        "vulnerability_results",
        "sbom",
        "image_scan"
      ],
      "properties": {
        "test_summary": { "$ref": "#/$defs/artifact" },
        "race_summary": { "$ref": "#/$defs/artifact" },
        "fuzz_summary": { "$ref": "#/$defs/artifact" },
        "fixture_manifest": { "$ref": "#/$defs/artifact" },
        "redis_summary": { "$ref": "#/$defs/artifact" },
        "temporal_summary": { "$ref": "#/$defs/artifact" },
        "compose_summary": { "$ref": "#/$defs/artifact" },
        "redis_log": { "$ref": "#/$defs/artifact" },
        "temporal_log": { "$ref": "#/$defs/artifact" },
        "compose_log": { "$ref": "#/$defs/artifact" },
        "rendered_manifests": { "$ref": "#/$defs/artifact" },
        "dependency_license": { "$ref": "#/$defs/artifact" },
        "vulnerability_results": { "$ref": "#/$defs/artifact" },
        "sbom": { "$ref": "#/$defs/artifact" },
        "image_scan": { "$ref": "#/$defs/artifact" }
      }
    }
  },
  "$defs": {
    "provenance_url": {
      "type": "string",
      "allOf": [
        {
          "pattern": "^https://[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?(?:\\.[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)*(?:/[A-Za-z0-9._~!$&'()*+,;=:@/-]*)?$"
        },
        {
          "not": {
            "pattern": "^https://[0-9]+(?:\\.[0-9]+)+(?:/|$)"
          }
        },
        {
          "not": {
            "pattern": "^https://[^/]{254,}(?:/|$)"
          }
        }
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "bytes",
        "sha256",
        "redacted"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 33554432
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "redacted": {
          "const": true
        }
      }
    }
  }
}
